# ─── Database ───────────────────────────────────────────────
DB_PASSWORD=root

# ─── JWT ────────────────────────────────────────────────────
JWT_SECRET=your-secret-key-at-least-32-chars-long

# ─── Email (optional) ──────────────────────────────────────
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-specific-password

# ─── Cache ──────────────────────────────────────────────────
CACHE_TYPE=redis

# ─── Kafka ──────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# ─── Hibernate ─────────────────────────────────────────────
HIBERNATE_DDL=update
